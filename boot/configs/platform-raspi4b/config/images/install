image boot.img {
	vfat {
		@BOOTFILES@
		file kernel8.img { image = "linuximage" }
		file initramfs8  { image = "install.cpio" }
		files += bcm2711-rpi-4-b.dtb
	}
	size = 48M
	temporary = true
}

image install_boot.vfat {
	vfat {
		files = { config.txt, boot.img }
	}
	size = 64M
	temporary = true
}

image install_payload.vfat {
	vfat {
		@PAYLOAD@
	}
	size = @SIZE@
	temporary = true
}

image install.img {
	hdimage { 
		partition-table-type = gpt
		align = 1M
	}
	partition rpi {
		image = install_boot.vfat
		partition-type-uuid = F
	}
	partition install {
		image = install_payload.vfat
		partition-type-uuid = F
	}
}
