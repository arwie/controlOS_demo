image install_linuximage.signed {
	custom {
		exec = 'cd ${PTXDIST_WORKSPACE}/../keys && sbsign --key sb.key --cert sb.crt --output ${IMAGEOUTFILE} ${INPUTPATH}/install_linuximage'
	}
}

image install_boot.vfat {
	vfat {
		file EFI/BOOT/BOOTx64.EFI { image = install_linuximage.signed }
	}
	size = 16M
	temporary = true
}

image install_payload.vfat {
	vfat {
		@PAYLOAD@
	}
	size = @SIZE@
	temporary = true
}

image install.img {
	hdimage { 
		partition-table-type = hybrid
		align = 1M
	}
	partition efi {
		image = install_boot.vfat
		partition-type = 0xEF
		bootable = true
	}
	partition install {
		image = install_payload.vfat
		partition-type = 0x0C
	}
}
