## CMDLINE_OVERRIDE: always keep enabled to prevent external cmdline injection (secure boot)
CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE_OVERRIDE=y

CONFIG_KERNEL_XZ=y

CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y

CONFIG_BLK_DEV_NVME=y

CONFIG_MMC=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PCI=y

CONFIG_TMPFS=y
CONFIG_KEXEC=y
CONFIG_KEXEC_FILE=y

CONFIG_TCG_TPM=y
CONFIG_TCG_CRB=y
CONFIG_TCG_TIS=y

# CONFIG_CPU_MITIGATIONS is not set
# CONFIG_IA32_EMULATION is not set
