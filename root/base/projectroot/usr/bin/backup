import socket, os
from argparse import ArgumentParser
from tempfile import TemporaryDirectory
from http import HTTPStatus
from http.server import BaseHTTPRequestHandler
from systemd import daemon
from shared import log
from shared.system import gpg, tar_create, reboot


parser = ArgumentParser()
parser.add_argument("--restore", action="store_true", help="restore backupt (from stdin)")
args = parser.parse_args()


def restore():
	with TemporaryDirectory(dir='/var/tmp', prefix='backup_') as tmp:
		gpg(
			'--decrypt',
			'--passphrase-file=/etc/gpg/backup.symkey',
			status={'NEED_PASSPHRASE_SYM','DECRYPTION_INFO','DECRYPTION_OKAY'},
			output=f'{tmp}/backup'
		)
		os.sync()
		os.rename(f'{tmp}/backup', '/var/backup')
	reboot()


def backup(capture:bool):
	tar = tar_create('/var', 'etc')
	return gpg(
		'--symmetric',
		'--passphrase-file=/etc/gpg/backup.symkey',
		'--encrypt',
		'--recipient-file=/etc/gpg/backup.pubkey',
		input=tar,
		output=capture
	)



class storeHttpHandler(BaseHTTPRequestHandler):
	def log_error(self, format, *args):
		log.error(format%args)
	
	def do_GET(self):
		try:
			binary = backup(True)
		except Exception as e:
			log.exception('ERROR in backup')
			self.send_error(HTTPStatus.INTERNAL_SERVER_ERROR, str(e))
			return
		
		self.send_response(HTTPStatus.OK)
		self.send_header('Content-Type',        'application/octet-stream')
		self.send_header('Content-Disposition', 'attachment; filename=backup.gpg')
		self.send_header('Content-Length',      str(len(binary)))
		self.end_headers()
		self.wfile.write(binary)


if daemon.listen_fds():
	systemdSocket = socket.fromfd(daemon.LISTEN_FDS_START, socket.AF_INET6, socket.SOCK_STREAM)
	storeHttpHandler(systemdSocket, systemdSocket.getpeername(), None) #type:ignore
elif args.restore:
	restore()
else:
	backup(False)
