import os, shutil
from argparse import ArgumentParser
from tempfile import TemporaryDirectory
from shared.system import run, gpg, tar_create, reboot


parser = ArgumentParser()
parser.add_argument("--bare", action="store_true", help="install unencrypted update (from stdin)")
parser.add_argument("--revert", action="store_true", help="revert last installed update")
args = parser.parse_args()


def update():
	with TemporaryDirectory(dir='/var/tmp', prefix='update_') as tmp:
		if args.bare:
			run(['dd', f'of={tmp}/update'])
		else:
			gpg(
				'--decrypt',
				'--passphrase-file=/etc/gpg/common.symkey',
				'--keyring=/etc/gpg/update.pubkey',
				status={'NEED_PASSPHRASE_SYM','DECRYPTION_INFO','DECRYPTION_OKAY','GOODSIG','VALIDSIG'},
				output=f'{tmp}/update'
			)
			os.mkdir(f'{tmp}/revert')
			tar_create('/mnt/root', '.', output=f'{tmp}/revert/update')
			tar_create('/var', 'etc',    output=f'{tmp}/revert/backup')
			os.sync()
			shutil.rmtree('/var/revert', ignore_errors=True)
			os.rename(f'{tmp}/revert', '/var/revert')

		os.sync()
		os.rename(f'{tmp}/update', '/var/update')
	reboot(False)


def revert():
	os.rename('/var/revert/update', '/var/update')
	os.rename('/var/revert/backup', '/var/backup')
	shutil.rmtree('/var/revert', ignore_errors=True)
	reboot(False)


if args.revert:
	revert()
else:
	update()
